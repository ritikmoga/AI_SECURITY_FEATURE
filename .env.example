# Flask
FLASK_DEBUG=false
PORT=5000
CORS_ORIGINS=*
SCAMSHIELD_VERSION=1.0.0

# Safety limits
MAX_FILE_SIZE_MB=10
RATE_LIMIT_PER_MINUTE=60
REPORT_STORAGE_PATH=./data/reports.json

# External reputation checks are optional. Keep false until keys are added.
EXTERNAL_CHECKS_ENABLED=false
GOOGLE_SAFE_BROWSING_API_KEY=
VIRUSTOTAL_API_KEY=
URLSCAN_API_KEY=

# Authentication and local persistence. Use a long random value in production.
DATABASE_PATH=./data/scamshield.db
AUTH_SECRET_KEY=change-this-in-production
# Google Cloud OAuth 2.0 Web client ID. Leave blank to hide Google sign-in.
GOOGLE_OAUTH_CLIENT_ID=
DATABASE_URL=
REDIS_URL=
JWT_ACCESS_TOKEN_MINUTES=20
JWT_REFRESH_TOKEN_DAYS=14
# Comma-separated emails granted access to /api/admin endpoints.
ADMIN_EMAILS=
